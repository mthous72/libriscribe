# LibriScribe environment configuration
# Leave API keys blank; enable a provider by adding its key in the Settings page
# (or here). Empty keys = the provider shows as "not configured" (off).

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google AI Studio
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash

# Anthropic Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-opus-20240229

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-coder-6.7b-instruct

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-haiku
